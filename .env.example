# Required — create a bot with @BotFather in Telegram (/newbot) and paste the token.
BOT_TOKEN=

# Optional — only for /ask. Free key (no card): https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Storage — a free Upstash Redis database (https://upstash.com). Needed for
# reminders and to-dos. Copy the REST URL and token from the Upstash console.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Scheduling — Upstash QStash (same account). Delivers reminders on time when
# hosted. Leave blank for local development (the dev server polls instead).
QSTASH_TOKEN=

# Any random string. Protects the reminder-delivery endpoint.
DELIVER_SECRET=
